# ─── Base de datos / infraestructura ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/limablue_agenda"
REDIS_URL="redis://localhost:6379"

# ─── Autenticación ────────────────────────────────────────────────────────────
JWT_SECRET="limablue-jwt-secret-change-in-production"
JWT_EXPIRES_IN="8h"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN="http://localhost:5180"

# ─── Sistema de Confirmación por Correo (Gmail API + OAuth 2.0) ────────────────
# IMPORTANTE (portabilidad): TODOS los enlaces del correo se construyen con estas
# URLs. Al pasar a producción, cambia SOLO estos valores a tus dominios https://.
API_BASE_URL="http://localhost:3002"           # backend (donde viven /confirmar y /cancelar)
APP_BASE_URL="http://localhost:5180"           # frontend (a dónde vuelve el usuario tras OAuth)

# Secreto independiente para firmar los tokens de los enlaces Confirmar/Cancelar.
# OBLIGATORIO en producción. Genera uno largo y aleatorio.
CONFIRM_TOKEN_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
CONFIRM_TOKEN_EXPIRES_IN="30d"

# Credenciales del proyecto OAuth de Google Cloud (ver README · sección OAuth).
# El REDIRECT_URI debe coincidir EXACTAMENTE con el registrado en Google Cloud y
# apuntar a: <API_BASE_URL>/api/v1/herramientas/mail-config/oauth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3002/api/v1/herramientas/mail-config/oauth/callback"

# Opcional: refresh token de respaldo. Normalmente NO hace falta ponerlo aquí,
# porque tras pulsar "Conectar cuenta de Google" se guarda en la tabla MailConfig
# de la base de datos. Útil solo para sembrar una cuenta sin pasar por la UI.
GOOGLE_REFRESH_TOKEN=""

# Remitente por defecto. El admin puede cambiarlo desde la UI (se guarda en DB).
# Debe coincidir con la cuenta de Gmail que autorices en el flujo OAuth.
MAIL_FROM_ADDRESS=""
MAIL_FROM_NAME="Limablue Podología"

# ── Resend (proveedor de correo actual) ───────────────────────────────────────
# API key estática de Resend. El dominio limablue.pe debe estar verificado en
# Resend. La key SOLO vive aquí (env); nunca en la base de datos ni en la UI.
RESEND_API_KEY=""
# Secreto para validar la firma (svix) de los webhooks entrantes de Resend
# (POST /api/v1/webhooks/resend): email.delivered / email.bounced / email.complained.
RESEND_WEBHOOK_SECRET=""

# ── Outlook Calendar (Microsoft Graph) — sincroniza citas de Yasica/Daniel Doy ──
# App en Azure AD/Entra ID con permiso de APLICACIÓN Calendars.ReadWrite (+ consentimiento admin)
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""

# ── Consulta de DNI RENIEC (apiperu.dev — basado en giansalex/peru-consult) ──
# Autollena nombres/apellidos del paciente al escribir el DNI. Obtén un token en
# https://apiperu.dev (el endpoint público /api/dni devuelve solo nombres+apellidos).
RENIEC_API_URL="https://apiperu.dev/api/dni"
RENIEC_API_TOKEN=""
