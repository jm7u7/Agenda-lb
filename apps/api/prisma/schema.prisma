generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, pgcrypto]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ModoReserva {
  preferencia_opcional // Podología
  sin_eleccion // Baropodometría
  preferencia_obligatoria // Fisioterapia
}

enum EstadoCita {
  agendada
  confirmada
  llego
  en_atencion
  completada
  no_show
  cancelada
  reprogramada
}

// Rol de una cita dentro de un BLOQUE COMBINADO (profilaxis + servicio extra en el
// mismo slot de 1 h). `PRINCIPAL` = el ancla (profilaxis, siempre); `SECUNDARIO` = el
// extra. null en `Cita.slotRol` = cita individual (no pertenece a ningún bloque).
enum SlotRol {
  PRINCIPAL
  SECUNDARIO
}

// Tipo de beneficio de una Promoción: precio fijo (S/ N), porcentaje de descuento (N%),
// u OTRO (sin valor numérico, p. ej. campañas tipo "ARIE SCANNER 3D").
enum TipoPromocion {
  PRECIO_FIJO
  PORCENTAJE
  OTRO
  MEMBRESIA // membresía con contabilidad de sesiones (constructor en Herramientas)
}

// Canal de reserva configurable (de dónde viene el cliente). Administrable desde Herramientas:
// se pueden agregar/quitar canales sin migración. `Cita.canal` guarda el `valor` (slug).
model Canal {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  valor         String    @unique // slug estable que se guarda en la cita (ej. "tiktok")
  etiqueta      String // texto visible (ej. "TikTok")
  orden         Int       @default(0)
  activo        Boolean   @default(true)
  deletedAt     DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@map("canales")
}

// Promoción configurable (administrable desde Herramientas). Una cita puede llevar una
// promoción (FK `Cita.promocionId`). En un BLOQUE COMBINADO la promo aplica UNA sola vez y
// vive solo en la cita PRINCIPAL (profilaxis) — ver `resolverCitaPortadora` en el backend.
model Promocion {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String
  descripcion   String?
  tipo          TipoPromocion @default(OTRO)
  valor         Decimal?      @db.Decimal(10, 2) // S/ (PRECIO_FIJO) o % (PORCENTAJE); null en OTRO
  activo        Boolean       @default(true)
  orden         Int           @default(0)
  deletedAt     DateTime?
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt

  citas Cita[]
  // Membresías (tipo=MEMBRESIA): plantilla de contabilidad de sesiones vinculada.
  paquetesPlantilla Paquete[]

  // Único por nombre mientras viva: índice único PARCIAL (WHERE deletedAt IS NULL) en la
  // migración — `promociones_nombre_unico`.
  @@map("promociones")
}

enum OrigenAsignacion {
  elegida_por_paciente
  asignada_automaticamente
}

enum TipoProfesional {
  podologa
  medico
  fisioterapeuta
}

enum TurnoHorario {
  manana
  tarde
  completo
}

enum TipoBloqueo {
  ALMUERZO
  CAPACITACION
  PERMISO
  OTRO
}

enum MotivoMovimiento {
  VACACIONES
  CAMBIO_POR_TIEMPO
  CERCANIA_A_CASA
  PROBLEMAS_INTERNOS
  COBERTURA_EMERGENCIA
  OTRO
}

enum TipoDocumento {
  DNI
  CE
  PASAPORTE
  RUC
  OTRO // documentos no estándar del import Genexis (incl. "SIN INFORMACIÓN" → OTRO)
}

enum Sexo {
  masculino
  femenino
  otro
}

// Estado de la confirmación por correo (independiente del ciclo de vida EstadoCita).
enum EstadoConfirmacion {
  pendiente
  confirmada
  cancelada
}

// Área de un agente de agendamiento (módulo Desempeño de Agentes). Independiente del
// rol (los roles son renombrables/editables); se backfillea desde el rol una sola vez
// y de ahí en más se administra desde la ficha del usuario. null = sin clasificar.
enum AreaAgente {
  CONTACT_CENTER
  RECEPCION
  OTRO
}

// ─── Sede ─────────────────────────────────────────────────────────────────────

model Sede {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre    String    @unique
  direccion String
  color     String    @default("#3B82F6")
  activa    Boolean   @default(true)
  // Orden manual de las pestañas de sede en la agenda (0 = sin orden → alfabético).
  orden     Int       @default(0)
  deletedAt DateTime?

  // Horario por día de semana (JSON: {lunes: {apertura: "08:00", cierre: "20:00"}, ...})
  horario Json @default("{}")

  unidadesNegocio SedeUnidadNegocio[]
  asignaciones    AsignacionSede[]
  // Roster administrativo (doctores + recepcionistas) — solo informativo, no afecta reservas.
  asignacionesAdmin AsignacionAdministrativa[]
  citas           Cita[]
  usuarios        UsuarioSede[]
  usuariosAsignados Usuario[]           @relation("UsuarioSedeAsignada")
  webhookSubs     WebhookSubscription[]
  excepciones     ExcepcionHorario[]
  agregados       AgregadoDiario[]
  notificaciones  NotificacionSede[]
  bloqueos        BloqueoAgenda[]
  paquetesPaciente PaquetePaciente[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("sedes")
}

// ─── Excepción de horario (cierres especiales, aperturas dominicales, etc.) ───

model ExcepcionHorario {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeId       String   @db.Uuid
  sede         Sede     @relation(fields: [sedeId], references: [id])
  fecha        DateTime @db.Date
  abierto      Boolean  @default(true)
  horaApertura String?
  horaCierre   String?
  nota         String?
  creadoEn     DateTime @default(now())

  @@unique([sedeId, fecha])
  @@map("excepciones_horario")
}

// ─── UnidadNegocio ────────────────────────────────────────────────────────────

model UnidadNegocio {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String      @unique
  modoReserva ModoReserva
  color       String      @default("#6366F1")
  activa      Boolean     @default(true)
  deletedAt   DateTime?

  sedes         SedeUnidadNegocio[]
  profesionales Profesional[]
  servicios     Servicio[]
  citas         Cita[]
  agregados     AgregadoDiario[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("unidades_negocio")
}

// ─── Relación Sede ↔ UnidadNegocio ───────────────────────────────────────────

model SedeUnidadNegocio {
  sedeId          String @db.Uuid
  unidadNegocioId String @db.Uuid

  sede          Sede          @relation(fields: [sedeId], references: [id])
  unidadNegocio UnidadNegocio @relation(fields: [unidadNegocioId], references: [id])

  @@id([sedeId, unidadNegocioId])
  @@map("sede_unidad_negocio")
}

// ─── Profesional ──────────────────────────────────────────────────────────────

model Profesional {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombres          String
  apellidos        String
  tipo             TipoProfesional
  unidadNegocioId  String          @db.Uuid
  colorAvatar      String          @default("#6B7F9E")
  activo           Boolean         @default(true)
  // "Solo por solicitud": nunca se auto-asigna ni aparece como columna fija en la agenda;
  // solo es seleccionable al reservar (médicos de baropodometría y Daniel Doy) y su columna
  // aparece únicamente el día que tiene citas. Puede atender en cualquier sede.
  soloPorSolicitud Boolean         @default(false)
  // Orden manual de la columna en la agenda: null = alfabético normal; un valor mayor
  // empuja la columna a la DERECHA (después de las normales y de las "Adicional").
  ordenAgenda      Int?
  // Meta mensual de días de presencia para el reporte de bonos de RRHH (null = usar el
  // valor global del filtro). Solo se usa en Reportes RRHH; no afecta la operación.
  metaDiasMes      Int?
  // Correo de notificación de agenda (canal correo + .ics) cuando el buzón NO es
  // accesible por Graph. Configurable en BD (antes hardcodeado). Yasica Doy →
  // yasicadoy@limablue.com. Daniel Doy se sincroniza por Graph y queda null.
  emailAgenda      String?
  deletedAt        DateTime?

  unidadNegocio    UnidadNegocio            @relation(fields: [unidadNegocioId], references: [id])
  asignaciones     AsignacionSede[]         @relation("AsignacionProfesional")
  reemplazado      AsignacionSede[]         @relation("Reemplazos")
  // Roster administrativo cuando el profesional es un "doctor" (baropodometría por solicitud).
  asignacionesAdmin AsignacionAdministrativa[] @relation("AsignacionAdminProfesional")
  horarios         HorarioProfesional[]
  bloqueos         BloqueoAgenda[]
  competencias     CompetenciaProfesional[]
  citas            Cita[]                   @relation("CitaProfesional")
  citasSolicitadas Cita[]                   @relation("CitaSolicitado")
  agregados        AgregadoDiario[]
  entradas         EntradaPodologa[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([activo])
  @@map("profesionales")
}

// ─── AsignacionSede ───────────────────────────────────────────────────────────

model AsignacionSede {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesionalId String           @db.Uuid
  sedeId        String           @db.Uuid
  fechaInicio   DateTime         @db.Date
  fechaFin      DateTime?        @db.Date
  activa        Boolean          @default(true)
  motivo        MotivoMovimiento @default(OTRO)
  reemplazaA    String?          @db.Uuid
  notas         String?
  creadoPor     String?          @db.Uuid
  // Asignación de RETORNO AUTOMÁTICO (devuelve a la sede matriz al terminar un movimiento
  // temporal). Marca estructural — NO detectar retornos por heurística de sede/fecha.
  esRetorno     Boolean          @default(false)

  // Para deshacer un movimiento con exactitud: qué asignación previa cerró este
  // movimiento y cuál era su fechaFin original (null = era indefinida). Al eliminar
  // el movimiento se restaura esa asignación a su estado exacto.
  cierraAsignacionId String?   @db.Uuid
  cierraFechaFin     DateTime? @db.Date

  profesional          Profesional  @relation("AsignacionProfesional", fields: [profesionalId], references: [id])
  sede                 Sede         @relation(fields: [sedeId], references: [id])
  reemplazaProfesional Profesional? @relation("Reemplazos", fields: [reemplazaA], references: [id])
  creadoPorUsuario     Usuario?     @relation(fields: [creadoPor], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([profesionalId, activa])
  @@index([sedeId, activa])
  @@index([fechaInicio, fechaFin])
  @@map("asignaciones_sede")
}

// ─── Recepcionista ────────────────────────────────────────────────────────────
// Ficha de personal SIN login (no es Usuario ni Profesional). Existe solo para el módulo
// de composición de sede: se crea y se le asignan sedes por periodo (roster administrativo).
// No tiene agenda, no impacta reservas.
model Recepcionista {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre    String
  activo    Boolean   @default(true)
  deletedAt DateTime?

  asignaciones AsignacionAdministrativa[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("recepcionistas")
}

// ─── AsignacionAdministrativa ─────────────────────────────────────────────────
// Roster administrativo: en qué sede está un DOCTOR (Profesional tipo=medico por solicitud)
// o una RECEPCIONISTA durante un rango de fechas. PURAMENTE INFORMATIVO para el módulo de
// composición de sede + PDF. El motor de disponibilidad y las reservas NO leen esta tabla,
// así que asignar aquí no afecta la agenda ni las citas. Exactamente uno de
// profesionalId / recepcionistaId debe estar presente (validado en el backend).
model AsignacionAdministrativa {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeId          String    @db.Uuid
  fechaInicio     DateTime  @db.Date
  fechaFin        DateTime? @db.Date // null = indefinida
  // Persona asignada: un doctor (profesionalId) O una recepcionista (recepcionistaId).
  profesionalId   String?   @db.Uuid
  recepcionistaId String?   @db.Uuid
  notas           String?
  creadoPor       String?   @db.Uuid // uuid del usuario (sin relación, solo auditoría)
  deletedAt       DateTime?

  sede          Sede           @relation(fields: [sedeId], references: [id])
  profesional   Profesional?   @relation("AsignacionAdminProfesional", fields: [profesionalId], references: [id])
  recepcionista Recepcionista? @relation(fields: [recepcionistaId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([sedeId, fechaInicio, fechaFin])
  @@index([profesionalId])
  @@index([recepcionistaId])
  @@map("asignaciones_administrativas")
}

// ─── HorarioProfesional ───────────────────────────────────────────────────────

model HorarioProfesional {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesionalId String       @db.Uuid
  diaSemana     Int // 0=Dom, 1=Lun, ..., 6=Sab
  horaInicio    String // "HH:mm"
  horaFin       String
  turno         TurnoHorario @default(completo)
  activo        Boolean      @default(true)

  profesional Profesional @relation(fields: [profesionalId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([profesionalId, diaSemana])
  @@map("horarios_profesional")
}

// ─── EntradaPodologa — OVERRIDE DE TURNO POR FECHA ────────────────────────────
// Sobrescribe el turno base (HorarioProfesional) de UNA fecha concreta: entrada
// distinta (08:00/09:00) y, opcionalmente, salida distinta. Es la CAPA 2 del
// resolvedor único `turnosDelDia` (capa 0 = ventana de sede, capa 1 = horario base).
// En días de EXCEPCIÓN de sede abierta (domingo/feriado) la fila además marca
// PRESENCIA: solo quien tiene fila atiende ese día. Las AUSENCIAS puntuales NO
// van aquí: son responsabilidad del módulo Permisos/Bloqueos (BloqueoAgenda).
model EntradaPodologa {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesionalId String   @db.Uuid
  fecha         DateTime @db.Date
  horaInicio    String // "08:00" | "09:00"
  horaFin       String? // opcional: sobreescribe la SALIDA ese día (null = usa la base)
  creadoPor     String?  @db.Uuid
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  profesional Profesional @relation(fields: [profesionalId], references: [id])

  @@unique([profesionalId, fecha])
  @@index([fecha])
  @@map("entradas_podologa")
}

// ─── BloqueoAgenda ────────────────────────────────────────────────────────────

model BloqueoAgenda {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesionalId String    @db.Uuid
  fechaInicio   DateTime
  fechaFin      DateTime
  motivo        String
  deletedAt     DateTime?

  // Campos para almuerzos y bloqueos recurrentes
  sedeId       String?     @db.Uuid
  tipo         TipoBloqueo @default(OTRO)
  esRecurrente Boolean     @default(false)
  // Reunión administrativa de Daniel/Yasica: se pinta VERDE en la agenda (vs rojo del permiso).
  esReunion    Boolean     @default(false)
  // Vacaciones planificadas: bloqueo de día completo (tipo PERMISO, esRecurrente=false) marcado
  // con esta bandera para pintarse como franja 🌴 "Vacaciones" en la agenda (vs rojo del permiso).
  // No cambia la semántica de disponibilidad (esta ya bloquea todo bloqueo no recurrente).
  esVacaciones Boolean     @default(false)
  // Sincronización con el calendario del celular del profesional (reuniones): id del evento
  // Outlook (Daniel) para update/cancel; último error de sync (null = OK) para el reintentador.
  outlookEventId   String?
  outlookSyncError String?
  horaInicio   String? // "HH:MM" — para bloqueos recurrentes de almuerzo
  horaFin      String? // "HH:MM" — calculado al crear
  duracionMin  Int         @default(60)
  creadoPor    String?     @db.Uuid

  profesional      Profesional @relation(fields: [profesionalId], references: [id])
  sede             Sede?       @relation(fields: [sedeId], references: [id])
  creadoPorUsuario Usuario?    @relation(fields: [creadoPor], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([profesionalId, fechaInicio, fechaFin])
  @@index([sedeId, tipo, esRecurrente])
  @@map("bloqueos_agenda")
}

// ─── Servicio ─────────────────────────────────────────────────────────────────

model Servicio {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre            String
  codigo            String    @unique
  duracionMinutos   Int       @default(30)
  color             String    @default("#6B7F9E")
  precioReferencial Decimal?  @db.Decimal(10, 2)
  unidadNegocioId   String    @db.Uuid
  activo            Boolean   @default(true)
  // Orden manual dentro de su unidad (0 = sin orden → alfabético). Sirve para listas
  // como "Promociones", que deben mostrarse en una secuencia específica, no alfabética.
  orden             Int       @default(0)
  deletedAt         DateTime?

  unidadNegocio UnidadNegocio            @relation(fields: [unidadNegocioId], references: [id])
  competencias  CompetenciaProfesional[]
  citas         Cita[]
  paquetes      Paquete[]
  agregados     AgregadoDiario[]
  combinaciones CombinacionPermitida[]
  anclaDe       ConfiguracionSistema[]
  subcategorias SubcategoriaServicio[]
  paquetesComoServicioNuevo PaquetePaciente[] @relation("PaqueteServicioNuevo")
  videos        ServicioVideo[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([unidadNegocioId, activo])
  @@map("servicios")
}

// ─── SubcategoriaServicio ─────────────────────────────────────────────────────
// Subcategorías/variantes de un Servicio (ej. Profilaxis → Regular, Premium,
// Infantil, Adulto mayor). Misma duración que el servicio padre; PRECIO propio.
// Cuando un servicio tiene subcategorías ACTIVAS, elegir una es OBLIGATORIO al
// agendar y al vender/consumir membresías (la subcategoría se FIJA al vender).
// Soft-delete + AuditLog. Configurable desde Administración (NO hardcodear).
model SubcategoriaServicio {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicioId        String    @db.Uuid
  nombre            String
  precioReferencial Decimal?  @db.Decimal(10, 2)
  orden             Int       @default(0)
  activo            Boolean   @default(true)
  deletedAt         DateTime?

  servicio Servicio @relation(fields: [servicioId], references: [id])
  citas    Cita[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Único por (servicio, nombre) mientras no esté borrado: índice único PARCIAL
  // `subcategorias_servicio_nombre_unico` (WHERE deletedAt IS NULL) — SQL crudo
  // en la migración `20260706160000_subcategorias_servicio`.
  @@index([servicioId, activo])
  @@map("subcategorias_servicio")
}

// ─── CombinacionPermitida ─────────────────────────────────────────────────────
// Servicios que pueden combinarse como EXTRA de una profilaxis (el ancla es siempre
// la profilaxis, así que basta una lista unidireccional de "extras permitidos").
// Configurable desde Herramientas (NO hardcodear cruces). Soft-delete + AuditLog.
model CombinacionPermitida {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicioExtraId String    @db.Uuid
  activo          Boolean   @default(true)
  deletedAt       DateTime?

  servicio Servicio @relation(fields: [servicioExtraId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Único por servicio mientras no esté borrado: refuerzo vía índice único PARCIAL
  // (WHERE deletedAt IS NULL) creado en la migración — `combinaciones_servicio_unico`.
  @@index([servicioExtraId])
  @@map("combinaciones_permitidas")
}

// ─── ConfiguracionSistema ─────────────────────────────────────────────────────
// Configuración global de fila única (patrón MailConfig). Por ahora guarda el
// servicio ANCLA para combinaciones (la profilaxis), elegido desde Herramientas.
// Extensible a futuras configuraciones globales.
model ConfiguracionSistema {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicioAnclaId String? @db.Uuid

  servicioAncla Servicio? @relation(fields: [servicioAnclaId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("configuracion_sistema")
}

// ─── CompetenciaProfesional ───────────────────────────────────────────────────

model CompetenciaProfesional {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesionalId    String   @db.Uuid
  servicioId       String   @db.Uuid
  habilitadoDesde  DateTime @db.Date
  activa           Boolean  @default(true)
  // "Solo por solicitud" a nivel de COMPETENCIA: este profesional realiza este servicio solo
  // cuando el paciente lo pide (no se auto-asigna, no es columna fija; aparece como opción al
  // reservar y como columna solo el día que tiene cita). Ej.: Daniel hace baropodometría solo
  // por solicitud, pero su podología es normal (columna fija en su sede).
  soloPorSolicitud Boolean  @default(false)

  profesional Profesional @relation(fields: [profesionalId], references: [id])
  servicio    Servicio    @relation(fields: [servicioId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([profesionalId, servicioId])
  @@index([servicioId, activa])
  @@map("competencias_profesional")
}

// ─── Paciente ─────────────────────────────────────────────────────────────────

// ─── Ubigeo (INEI) — distritos del Perú para "distrito de residencia" ─────────
// Fuente de verdad: código INEI de 6 dígitos (prisma/data/ubigeo-peru.json, 1892
// distritos). Dos filas ESPECIALES con códigos imposibles en INEI:
//   999999 = "Extranjero (reside fuera del Perú)"  → exige Paciente.paisResidencia
//   999998 = "No precisa"
model Ubigeo {
  id           String    @id // código INEI 6 dígitos, ej. "150131" = San Isidro
  distrito     String
  provincia    String
  departamento String
  esLimaMetro  Boolean   @default(false) // provincia Lima (1501xx) + Callao (0701xx)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  pacientes Paciente[]

  @@map("ubigeos")
}

model Paciente {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombres         String
  apellidoPaterno String
  apellidoMaterno String
  tipoDocumento   TipoDocumento @default(DNI)
  numeroDocumento String
  fechaNacimiento DateTime?     @db.Date
  sexo            Sexo?
  telefono        String
  email           String?
  // Soft: correo rebotado/quejado (bounce/complaint vía webhook de Resend). Se
  // EXCLUYE de futuros envíos sin borrar el email. Se limpia si el correo se corrige.
  emailInvalido   Boolean       @default(false)
  notas           String?
  // Distrito de residencia (UBIGEO INEI). null = no capturado (54K+ legados).
  ubigeoId        String?
  ubigeo          Ubigeo?       @relation(fields: [ubigeoId], references: [id])
  // País de residencia ISO 3166-1 alpha-2 ("VE","CO"...). SOLO cuando
  // ubigeoId = 999999 (Extranjero); en cualquier otro caso el backend fuerza null.
  paisResidencia  String?
  deletedAt       DateTime?

  // ─── Import Genexis (migración del sistema antiguo) ──────────────────────────
  // origenImportacion = "GENEXIS" cuando el paciente fue CREADO por el import.
  // requiereActualizacionDatos es CALCULADA server-side (falta correo/teléfono/
  // fechaNacimiento) — nunca se setea manualmente desde el cliente.
  origenImportacion          String?
  loteImportacionId          String?   @db.Uuid
  requiereActualizacionDatos Boolean   @default(false)

  citas          Cita[]
  paquetes       PaquetePaciente[]
  conciliaciones ConciliacionApertura[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Índices para búsqueda rápida
  @@index([numeroDocumento])
  @@index([telefono])
  @@index([ubigeoId])
  // GIN trigram indexes are created via raw SQL in migration
  @@map("pacientes")
}

// ─── Cita ─────────────────────────────────────────────────────────────────────

model Cita {
  id                      String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pacienteId              String            @db.Uuid
  profesionalId           String?           @db.Uuid // null en Baropodometría hasta asignación
  solicitadoProfesionalId String?           @db.Uuid // médico pedido "Solo X" (baro): la cita va en una máquina
  sedeId                  String            @db.Uuid
  unidadNegocioId         String            @db.Uuid
  servicioId              String            @db.Uuid
  fecha                   DateTime          @db.Date
  horaInicio              String // "HH:mm"
  duracionMinutos         Int
  estado                  EstadoCita        @default(agendada)
  // Momento en que se marcó "Llegó" (ancla para el auto-completado por tiempo: 90 min después
  // pasa a 'completada' automáticamente). Se reinicia si se revierte una cita ya atendida.
  llegoEn                 DateTime?
  canal                   String            @default("recepcion") // valor de un Canal configurable
  origenAsignacion        OrigenAsignacion?
  paquetePacienteId       String?           @db.Uuid
  // Subcategoría del servicio (ej. Profilaxis → Regular/Premium/Infantil/Adulto mayor).
  // Obligatoria a nivel de aplicación cuando el servicio tiene subcategorías activas;
  // nullable en DB por additive-only (citas viejas y servicios sin subcategorías = null).
  subcategoriaId          String?           @db.Uuid
  sesionNumero            Int?
  // Marca si ESTA cita ya descontó una sesión del paquete. Hace idempotente el
  // descuento/reembolso: una cita consume a lo sumo 1 sesión, sin importar
  // cuántas veces se cambie su estado.
  sesionConsumida         Boolean           @default(false)
  motivoCancelacion       String?
  consultorioNumero       Int?
  citaOriginalId          String?           @db.Uuid // si esta cita es reprogramación de otra
  deletedAt               DateTime?

  // ─── Bloque combinado (profilaxis + servicio extra en el mismo slot de 1 h) ──
  // null = cita individual. Si != null, esta cita pertenece a un bloque de 2 citas
  // que comparten el mismo intervalo horario. `slotRol` distingue ancla vs extra.
  slotGrupoId             String?           @db.Uuid
  slotRol                 SlotRol?

  // Promoción aplicada a la cita (opcional). En un bloque combinado vive SOLO en la cita
  // PRINCIPAL (profilaxis); la SECUNDARIO lleva null. FK en Restrict (ver Promocion).
  promocionId             String?           @db.Uuid

  // Comprobante de pago anticipado (opcional)
  comprobanteUrl       String?
  comprobanteNombre    String?
  comprobanteMimeType  String?
  comprobanteSubidoPor String?   @db.Uuid
  comprobanteSubidoEn  DateTime?

  // Confirmación de cita por correo
  estadoConfirmacion    EstadoConfirmacion @default(pendiente)
  confirmacionToken     String? // JWT firmado con CONFIRM_TOKEN_SECRET
  confirmacionEnviadaEn DateTime? // última vez que se envió el correo
  confirmadaEn          DateTime? // cuándo el paciente confirmó desde el enlace

  // Sincronización con Outlook Calendar (solo Yasica/Daniel Doy vía Microsoft Graph)
  outlookEventId   String? // id del evento en el buzón del profesional (para update/cancel)
  outlookSyncError String? // último error de sincronización (null si OK) — para reintento

  // Quién hizo la reserva (usuario del sistema que la creó) — se llena en cada nueva cita.
  creadoPorUsuarioId String? @db.Uuid

  // Clave de idempotencia (para no duplicar al reintentar). NO se muestra; va en su propio campo
  // (antes se metía dentro del comentario como [IK:...] y se filtraba a la vista).
  idempotencyKey String?

  paciente              Paciente           @relation(fields: [pacienteId], references: [id])
  creadoPorUsuario      Usuario?           @relation("CitasCreadas", fields: [creadoPorUsuarioId], references: [id])
  profesional           Profesional?       @relation("CitaProfesional", fields: [profesionalId], references: [id])
  solicitadoProfesional Profesional?       @relation("CitaSolicitado", fields: [solicitadoProfesionalId], references: [id])
  sede                  Sede               @relation(fields: [sedeId], references: [id])
  unidadNegocio         UnidadNegocio      @relation(fields: [unidadNegocioId], references: [id])
  servicio              Servicio           @relation(fields: [servicioId], references: [id])
  subcategoria          SubcategoriaServicio? @relation(fields: [subcategoriaId], references: [id])
  paquetePaciente       PaquetePaciente?   @relation(fields: [paquetePacienteId], references: [id])
  promocion             Promocion?         @relation(fields: [promocionId], references: [id], onDelete: Restrict)
  citaOriginal          Cita?              @relation("Reprogramacion", fields: [citaOriginalId], references: [id])
  reprogramaciones      Cita[]             @relation("Reprogramacion")
  auditLogs             AuditLog[]
  recordatorios         RecordatorioCita[]
  tokensAccion          TokenAccionCita[]
  comentarios           ComentarioCita[]
  consumosSesion        ConsumoSesion[]
  videoEnvios           VideoEnvioLog[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Anti double-booking: DOS índices únicos PARCIALES (solo citas activas) creados vía
  // SQL crudo en la migración `20260624120000_bloques_combinados`:
  //  • `citas_slot_primario_unique`  : slotRol NULL (cita suelta) o PRINCIPAL (ancla de
  //    bloque) — máx 1 por (profesionalId, fecha, horaInicio).
  //  • `citas_slot_secundario_unique`: slotRol SECUNDARIO (extra del bloque) — máx 1
  //    por (profesionalId, fecha, horaInicio).
  // Ambos excluyen estados cancelada/no_show/reprogramada y soft-deleted, para que al
  // cancelar una cita su slot quede libre para reservar de nuevo (sin perder la cita
  // del historial). Reemplazan al antiguo `citas_slot_activo_unique` (ya no existe).
  @@index([idempotencyKey])
  @@index([sedeId, fecha])
  @@index([profesionalId, fecha])
  @@index([pacienteId])
  @@index([promocionId])
  @@index([estado])
  @@index([unidadNegocioId, fecha])
  @@index([slotGrupoId])
  @@index([subcategoriaId])
  // Desempeño de Agentes: consultas por autor de la reserva en un rango de fechas.
  @@index([creadoPorUsuarioId, fecha])
  @@map("citas")
}

// ─── ComentarioCita (hilo APPEND-ONLY) ───────────────────────────────────────
// Cada comentario es una ENTRADA inmutable del hilo de la cita. No se edita ni se
// borra físicamente (solo `deletedAt` para ocultar). Dos usuarios comentando a la
// vez generan dos entradas independientes → imposible pisarse (sin last-write-wins).
// `autorEtiqueta` guarda el nombre del autor al momento de escribir (snapshot), para
// que el hilo sea legible aunque el Usuario se borre o sea un autor legacy/sistema.
model ComentarioCita {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  citaId        String    @db.Uuid
  autorId       String?   @db.Uuid // Usuario que escribió (null = legacy/sistema)
  autorEtiqueta String? // nombre mostrado, capturado al escribir (ej. "Recepción (legacy)")
  texto         String
  creadoEn      DateTime  @default(now())
  deletedAt     DateTime?

  cita  Cita     @relation(fields: [citaId], references: [id], onDelete: Restrict)
  autor Usuario? @relation(fields: [autorId], references: [id], onDelete: SetNull)

  @@index([citaId, creadoEn])
  @@map("comentarios_cita")
}

// ─── Paquete (plantilla) ──────────────────────────────────────────────────────

model Paquete {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String
  servicioId    String    @db.Uuid
  totalSesiones Int
  consumeNoShow Boolean   @default(false)
  precio        Decimal?  @db.Decimal(10, 2)
  activo        Boolean   @default(true)
  deletedAt     DateTime?

  // ─── Módulo Sesiones/Membresías (additive) ────────────────────────────────
  // tipo PAQUETE | MEMBRESIA | UNITARIA. `activo=false` desactiva la VENTA
  // (jamás se borra: instancias existentes/migradas siguen consumibles).
  tipo             String  @default("PAQUETE")
  // Membresías: composición vigente [{servicioId, cantidad, etiqueta}] — al VENDER
  // se copia como snapshot al PaquetePaciente (editar aquí NO toca lo vendido).
  composicion      Json?
  duracionMeses    Int?
  sedesHabilitadas Json? // lista de sedeIds donde se vende (null = todas)
  promocionId      String? @db.Uuid // membresías viven en el módulo Promociones

  servicio   Servicio          @relation(fields: [servicioId], references: [id])
  promocion  Promocion?        @relation(fields: [promocionId], references: [id])
  instancias PaquetePaciente[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("paquetes")
}

// ─── PaquetePaciente (instancia) ──────────────────────────────────────────────

model PaquetePaciente {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pacienteId     String    @db.Uuid
  paqueteId      String    @db.Uuid
  fechaCompra    DateTime  @db.Date
  sesionesTotal  Int
  // CONTADOR LEGACY (write-through): se mantiene sincronizado con el conteo de
  // ConsumoSesion vivos, que es LA fuente de verdad del saldo. Invariante
  // verificada en tests: sesionesUsadas == count(consumos vivos).
  sesionesUsadas Int       @default(0)
  activo         Boolean   @default(true)
  notas          String?
  deletedAt      DateTime?

  // ─── Módulo Sesiones/Membresías (additive) ────────────────────────────────
  // Candado de sede: el paquete se atiende donde se compró. Obligatorio a nivel
  // de aplicación para todo paquete nuevo (nullable en DB por additive-only;
  // los 9 legacy se backfillean).
  sedeId          String? @db.Uuid
  // Servicio RESUELTO del catálogo nuevo (gancho de la continuidad Genexis→Agenda;
  // en familias con mapeo porSede se resuelve con la sede del paquete).
  servicioNuevoId String? @db.Uuid
  tipo            String  @default("PAQUETE") // PAQUETE | MEMBRESIA | UNITARIA
  // Snapshot de composición al VENDER una membresía (regla de versionado:
  // editar el constructor no altera lo vendido).
  composicion     Json?
  vigenciaInicio  String? // "YYYY-MM-DD" — solo membresías
  vigenciaFin     String? // "YYYY-MM-DD" — solo membresías; null en paquetes = sin vencimiento
  origen          String  @default("AGENDA") // AGENDA | GENEXIS_APERTURA
  promocionId     String? @db.Uuid // membresía de la que nace (módulo Promociones)
  familiaId       String? @db.Uuid // FamiliaPaqueteGenexis de la apertura
  // Recalculado SIEMPRE server-side (ACTIVO | AGOTADO | VENCIDO | ANULADO) —
  // nunca aceptado del cliente.
  estado          String  @default("ACTIVO")

  paciente       Paciente               @relation(fields: [pacienteId], references: [id])
  paquete        Paquete                @relation(fields: [paqueteId], references: [id])
  sede           Sede?                  @relation(fields: [sedeId], references: [id])
  servicioNuevo  Servicio?              @relation("PaqueteServicioNuevo", fields: [servicioNuevoId], references: [id])
  familia        FamiliaPaqueteGenexis? @relation(fields: [familiaId], references: [id])
  citas          Cita[]
  consumos       ConsumoSesion[]
  conciliaciones ConciliacionApertura[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([pacienteId, activo])
  @@index([pacienteId, servicioNuevoId, sedeId, estado])
  @@map("paquetes_paciente")
}

// ─── Módulo Sesiones: FamiliaPaqueteGenexis ──────────────────────────────────
// Tabla de equivalencias APROBADA (solo para la migración): familia de nombres
// del sistema viejo → servicio del catálogo nuevo. `mapeoServicio` es
// {default: servicioId} o {porSede: {sedeId: servicioId}} (fisio se resuelve
// por sede). tipo SIN_SALDO (curaciones) y UNITARIA (Laser Para Hongos) NO
// generan propuestas de saldo.

model FamiliaPaqueteGenexis {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombreFamilia    String    @unique
  patronesServicio Json // regex/strings que matchean nombres viejos de servicio
  patronesObs      Json? // regex adicionales para la evidencia B
  mapeoServicio    Json? // {default} | {porSede} | null = sin equivalente
  tipo             String // PAQUETE | MEMBRESIA | UNITARIA | SIN_SALDO
  sesionesTotales  Int?
  composicion      Json? // membresías: [{servicioId, cantidad, etiqueta}]
  duracionMeses    Int?
  activa           Boolean   @default(true)
  deletedAt        DateTime?

  paquetes       PaquetePaciente[]
  conciliaciones ConciliacionApertura[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("familias_paquete_genexis")
}

// ─── Módulo Sesiones: ConsumoSesion (FUENTE DE VERDAD del saldo) ─────────────
// Cada uso de una sesión. Saldo = sesionesTotal − count(consumos vivos).
// Anular la cita consumidora → soft-delete del consumo (devolución automática).
// El saldo JAMÁS se edita: toda corrección es un consumo/anulación trazable.

model ConsumoSesion {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paqueteId          String    @db.Uuid
  // Membresías multi-ítem: servicioId del ítem del snapshot que descuenta.
  tipoSesion         String?   @db.Uuid
  citaId             String?   @db.Uuid // null SOLO en consumos de APERTURA
  historialGenexisId String?   @db.Uuid // evidencia del consumo histórico (FK débil)
  fecha              String // "YYYY-MM-DD"
  origen             String // APERTURA | CITA | AJUSTE_MANUAL
  motivo             String? // obligatorio si AJUSTE_MANUAL (validado en app)
  registradoPorId    String?   @db.Uuid // FK débil a Usuario
  registradoPor      String? // etiqueta snapshot (patrón ComentarioCita)
  anuladoMotivo      String? // motivo de la anulación (al soft-delete manual)
  deletedAt          DateTime?

  paquete PaquetePaciente @relation(fields: [paqueteId], references: [id])
  cita    Cita?           @relation(fields: [citaId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Máx 1 consumo VIVO por cita: índice único PARCIAL `consumos_cita_unico`
  // (WHERE citaId IS NOT NULL AND deletedAt IS NULL) — SQL crudo en la migración.
  @@index([paqueteId, deletedAt])
  @@index([citaId])
  @@map("consumos_sesion")
}

// ─── Módulo Sesiones: ConciliacionApertura (la firma humana) ─────────────────
// El motor propone (PENDIENTE); un humano aprueba/edita/descarta. Aprobar crea
// el PaquetePaciente + consumos APERTURA en transacción. El motor jamás toca
// filas decididas.

model ConciliacionApertura {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pacienteId         String  @db.Uuid
  familiaId          String  @db.Uuid
  paquetePacienteId  String? @db.Uuid // se llena al APROBAR
  lecturaServicio    Int? // evidencia A (nombres)
  lecturaObs         Int? // evidencia B (observaciones)
  consumoPropuesto   Int? // null = ILEGIBLE (decisión 100% humana)
  consumoAprobado    Int?
  // Tamaño REAL del paquete detectado en la obs ("de paquete de N sesiones"): manda
  // sobre el tamaño de la familia (el nombre de servicio a veces dice P12 pero el
  // paciente compró un paquete de 4). null = usar el tamaño de la familia.
  sesionesTotalReal  Int?
  ajusteProCliente   Boolean @default(false)
  confianza          String // VERDE | AMBAR | ROJO
  sedeInferidaId     String? @db.Uuid
  sedeAprobadaId     String? @db.Uuid
  servicioResueltoId String? @db.Uuid // mapeo de la familia según sede inferida/aprobada
  // Membresías: vigencia estimada (primera sesión + duración) y flag si ya
  // venció pero hay consumo 2026 (revisión humana de vigencia).
  vigenciaFinEstimada String?
  flagVigencia        Boolean @default(false)
  evidenciaIds        Json // ids de historial_genexis usados
  estado              String  @default("PENDIENTE") // PENDIENTE|APROBADA|EDITADA|DESCARTADA
  valoresOriginales   Json? // snapshot pre-edición (EDITADA preserva el original)
  decididoPor         String?
  decididoEn          DateTime?
  notas               String?
  deletedAt           DateTime?

  paciente        Paciente              @relation(fields: [pacienteId], references: [id])
  familia         FamiliaPaqueteGenexis @relation(fields: [familiaId], references: [id])
  paquetePaciente PaquetePaciente?      @relation(fields: [paquetePacienteId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([estado, confianza])
  @@index([pacienteId])
  @@index([familiaId, estado])
  @@map("conciliaciones_apertura")
}

// ─── Usuario ──────────────────────────────────────────────────────────────────

model Usuario {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre       String
  email        String    @unique
  passwordHash String
  rol          String    @default("recepcionista")
  activo       Boolean   @default(true)
  deletedAt    DateTime?

  // Desempeño de Agentes: área del agente (null = sin clasificar) y su sede "principal"
  // para reportes (null = multi-sede o no aplica). NO reemplaza a UsuarioSede (acceso).
  area           AreaAgente?
  sedeAsignadaId String?     @db.Uuid
  sedeAsignada   Sede?       @relation("UsuarioSedeAsignada", fields: [sedeAsignadaId], references: [id])

  sedes                 UsuarioSede[]
  apiKeys               ApiKey[]
  auditLogs             AuditLog[]
  asignacionesCreadas   AsignacionSede[]
  notificacionesCreadas Notificacion[]
  notificacionesVistas  NotificacionVista[]
  bloqueosCreados       BloqueoAgenda[]
  citasCreadas          Cita[]              @relation("CitasCreadas")
  comentariosCita       ComentarioCita[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("usuarios")
}

// ─── Rol ──────────────────────────────────────────────────────────────────────

model Rol {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String   @unique
  label         String
  descripcion   String?
  permisos      String[]
  esSistema     Boolean  @default(false)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("roles")
}

// ─── UsuarioSede ──────────────────────────────────────────────────────────────

model UsuarioSede {
  usuarioId String @db.Uuid
  sedeId    String @db.Uuid

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  sede    Sede    @relation(fields: [sedeId], references: [id])

  @@id([usuarioId, sedeId])
  @@map("usuarios_sedes")
}

// ─── ApiKey ───────────────────────────────────────────────────────────────────

model ApiKey {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre    String
  keyHash   String    @unique
  scopes    String[] // ["availability:read", "appointments:write", "patients:read"]
  usuarioId String?   @db.Uuid
  activa    Boolean   @default(true)
  ultimoUso DateTime?
  deletedAt DateTime?

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("api_keys")
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  citaId    String? @db.Uuid
  usuarioId String? @db.Uuid
  accion    String // "crear", "mover", "cambiar_estado", "cancelar", "redistribuir"
  entidad   String // "cita", "paciente", "profesional", etc.
  entidadId String  @db.Uuid
  antes     Json?
  despues   Json?
  sedeId    String? @db.Uuid
  ip        String?
  userAgent String?

  cita    Cita?    @relation(fields: [citaId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  creadoEn DateTime @default(now())

  @@index([citaId])
  @@index([usuarioId])
  @@index([sedeId, creadoEn])
  @@index([entidad, entidadId])
  @@map("audit_logs")
}

// ─── WebhookSubscription ──────────────────────────────────────────────────────

model WebhookSubscription {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre    String
  url       String
  secret    String
  eventos   String[] // ["appointment.created", "appointment.cancelled", ...]
  sedeId    String?   @db.Uuid // null = todas las sedes
  activa    Boolean   @default(true)
  deletedAt DateTime?

  sede Sede? @relation(fields: [sedeId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("webhook_subscriptions")
}

// ─── WebhookLog ───────────────────────────────────────────────────────────────

model WebhookLog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String    @db.Uuid
  evento         String
  payload        Json
  statusCode     Int?
  respuesta      String?
  intentos       Int       @default(1)
  exitoso        Boolean   @default(false)
  proximoIntento DateTime?

  creadoEn DateTime @default(now())

  @@index([subscriptionId, creadoEn])
  @@map("webhook_logs")
}

// ─── AgregadoDiario ───────────────────────────────────────────────────────────
// Una fila por combinación fecha + sede + unidadNegocio + profesional + servicio.
// El job de agregación usa delete+insert en transacción — sin unique constraint
// para evitar el problema NULL != NULL en PostgreSQL con profesionalId nullable.

model AgregadoDiario {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  fecha           DateTime @db.Date
  sedeId          String   @db.Uuid
  unidadNegocioId String   @db.Uuid
  profesionalId   String?  @db.Uuid
  servicioId      String   @db.Uuid

  // Contadores de estado
  totalCitas  Int @default(0)
  completadas Int @default(0)
  noShow      Int @default(0)
  canceladas  Int @default(0)
  llegaron    Int @default(0)
  agendadas   Int @default(0)
  confirmadas Int @default(0)
  enAtencion  Int @default(0)

  // Minutos
  minutosDisponibles Int @default(0) // sum(duracionMinutos) de todas
  minutosAtendidos   Int @default(0) // sum(duracionMinutos) de completadas

  // Origen asignación
  citasElegidasPorPaciente Int @default(0)
  citasAsignadasAuto       Int @default(0)

  // Marca para re-agregar si hubo cambios en el día
  sucio Boolean @default(false)

  sede          Sede          @relation(fields: [sedeId], references: [id])
  unidadNegocio UnidadNegocio @relation(fields: [unidadNegocioId], references: [id])
  profesional   Profesional?  @relation(fields: [profesionalId], references: [id])
  servicio      Servicio      @relation(fields: [servicioId], references: [id])

  actualizadoEn DateTime @updatedAt

  @@index([fecha, sedeId])
  @@index([fecha, unidadNegocioId])
  @@index([fecha, profesionalId])
  @@index([fecha, sedeId, unidadNegocioId])
  @@map("agregados_diarios")
}

// ─── Notificaciones ───────────────────────────────────────────────────────────

model Notificacion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mensaje       String   @db.VarChar(500)
  creadoPor     String   @db.Uuid
  creadoEn      DateTime @default(now())
  activaDesde   DateTime @default(now())
  activaHasta   DateTime
  todasLasSedes Boolean  @default(true)

  autor  Usuario             @relation(fields: [creadoPor], references: [id])
  sedes  NotificacionSede[]
  vistas NotificacionVista[]

  @@map("notificaciones")
}

model NotificacionSede {
  notificacionId String       @db.Uuid
  sedeId         String       @db.Uuid
  notificacion   Notificacion @relation(fields: [notificacionId], references: [id], onDelete: Cascade)
  sede           Sede         @relation(fields: [sedeId], references: [id])

  @@id([notificacionId, sedeId])
  @@map("notificaciones_sede")
}

model NotificacionVista {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificacionId String       @db.Uuid
  usuarioId      String       @db.Uuid
  vistaEn        DateTime     @default(now())
  notificacion   Notificacion @relation(fields: [notificacionId], references: [id], onDelete: Cascade)
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])

  @@unique([notificacionId, usuarioId])
  @@map("notificaciones_vista")
}

// ─── MailConfig ───────────────────────────────────────────────────────────────
// Configuración del remitente de correos de confirmación. Solo una fila activa.
// Las credenciales OAuth del cliente (CLIENT_ID/SECRET/REDIRECT_URI) viven en .env;
// aquí se persiste el correo activo, el nombre a mostrar y el refresh token de la
// cuenta autorizada — para poder cambiar de cuenta desde la UI sin redeploy.
// El refreshToken NUNCA se devuelve por la API (ver routes/herramientas.ts).
model MailConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromEmail     String // correo remitente (Gmail de prueba o @limablue)
  fromName      String   @default("Limablue Podología")
  provider      String   @default("resend") // Resend (transporte actual). Gmail quedó DEPRECADO.
  refreshToken  String? // DEPRECADO (token OAuth Gmail) — se conserva, no se usa con Resend
  isActive      Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("mail_config")
}

// ─── Recordatorios de cita (confirmación masiva por correo) ───────────────────
enum TipoRecordatorio {
  RESERVA // Correo 1 — confirmación de reserva (inmediato)
  RECORDATORIO // Correo 2 — recordatorio con acciones (cita − 2h / 1h / inmediato)
}

enum EstadoRecordatorio {
  PROGRAMADO
  ENVIADO
  FALLIDO
  CANCELADO
}

model RecordatorioCita {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  citaId             String             @db.Uuid
  tipo               TipoRecordatorio
  programadoPara     DateTime
  estado             EstadoRecordatorio @default(PROGRAMADO)
  intentos           Int                @default(0)
  gmailMessageId     String? // DEPRECADO (transporte Gmail) — se conserva por historial
  resendEmailId      String? // id del correo en Resend (transporte actual)
  enviadoAt          DateTime? // momento real de envío (para métricas de tiempo)
  jobId              String? // id del job en BullMQ (para cancelar/reagendar)
  clickConfirmarAt   DateTime?
  clickReprogramarAt DateTime?
  confirmadoAt       DateTime?
  errorMensaje       String?
  deletedAt          DateTime?

  cita Cita @relation(fields: [citaId], references: [id])

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([citaId])
  @@index([estado, programadoPara])
  @@index([programadoPara])
  // Idempotencia "un recordatorio por cita+tipo" se refuerza con un índice único
  // PARCIAL (solo no borrados) creado vía SQL crudo: recordatorios_cita_unico.
  @@map("recordatorios_cita")
}

// ─── Import Genexis ───────────────────────────────────────────────────────────
// Lote de importación del sistema antiguo Genexis (pacientes + historial congelado).
// Cada corrida del script `import-genexis` crea un lote con sus contadores; el
// historial insertado referencia su lote vía `loteId` (FK débil, sin constraint).

model ImportGenexisLote {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombreArchivo String
  tipo          String // "INICIAL" | "DELTA"
  totalFilas    Int

  pacientesCreados      Int @default(0)
  pacientesActualizados Int @default(0)
  pacientesOmitidos     Int @default(0)
  historialInsertado    Int @default(0)
  historialOmitido      Int @default(0)

  estado       String    @default("EN_PROCESO") // EN_PROCESO | COMPLETADO | FALLIDO
  errores      Json?
  importadoEn  DateTime  @default(now())
  importadoPor String
  deletedAt    DateTime?

  actualizadoEn DateTime @updatedAt

  @@map("import_genexis_lotes")
}

// Historial de atenciones del sistema antiguo Genexis: CRUDO y CONGELADO.
// Solo lectura a nivel de API (sin endpoints de escritura). Los campos podologo/
// sede/servicio son TEXTO CRUDO — jamás FK a los catálogos actuales. No aparece
// en KPIs ni analytics. `hashRegistro` (SHA-256 de campos normalizados) es la
// clave de idempotencia: re-ejecuciones y deltas se omiten con skipDuplicates.

model HistorialGenexis {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pacienteId        String? @db.Uuid // FK débil al Paciente real; null si no resolvió
  tipoDocumento     String // texto crudo (incluye "OTRO", "SIN INFORMACIÓN")
  numeroDocumento   String
  fechaCita         String // "YYYY-MM-DD" (fecha civil como string — regla del proyecto)
  horaCita          String? // tal cual el archivo (ej. "16")
  podologo          String? // texto crudo, NO FK
  sede              String? // texto crudo, NO FK (ej. "San Isidro" del sistema viejo)
  idSucursal        String?
  servicio          String? // texto crudo, NO FK — jamás toca el catálogo
  obsPaciente       String?
  obsPodologo       String?
  consultorio       String?
  llegoPaciente     String? // "Sí" | "No" | null
  fechaCreacionGx   String? // "YYYY-MM-DD HH:MM"
  usuarioCreacionGx String?
  hashRegistro      String  @unique // clave de idempotencia
  loteId            String  @db.Uuid

  creadoEn  DateTime  @default(now())
  deletedAt DateTime?

  @@index([pacienteId, fechaCita])
  @@index([numeroDocumento])
  @@index([loteId])
  @@map("historial_genexis")
}

model TokenAccionCita {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique
  citaId    String    @db.Uuid
  accion    String // "confirmar" | "reprogramar"
  expiraEn  DateTime
  usadoAt   DateTime? // single-use: una vez usado, se rechaza
  deletedAt DateTime?

  cita Cita @relation(fields: [citaId], references: [id])

  creadoEn DateTime @default(now())

  @@index([citaId])
  @@map("tokens_accion_cita")
}

// ─── Módulo Videos por Servicio ───────────────────────────────────────────────
// Videos educativos (YouTube "No listado") que se envían por correo al paciente,
// parametrizados por servicio y por momento relativo a la cita (antes/después).
// El transporte de correo es Resend (emailService.enviarEmail) — NO toca mail_config.

enum MomentoVideo {
  ANTES
  DESPUES
}

enum UnidadOffset {
  HORAS
  DIAS
  MESES
  ANIOS
}

enum EstadoEnvioVideo {
  PENDIENTE
  ENVIADO
  CANCELADO
  ERROR
}

// Un video configurado para un servicio. N videos por servicio. Cada uno define su
// momento (ANTES/DESPUES) y offset (valor + unidad) relativo a la cita. Soft-delete +
// AuditLog en toda creación/edición/toggle/eliminación. `activo` permite pausar sin borrar.
model ServicioVideo {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicioId     String       @db.Uuid
  youtubeVideoId String // extraído de la URL (11 chars normalmente)
  youtubeUrl     String // URL original pegada por el admin
  asunto         String // asunto del correo (máx 120 en validación) — soporta {paciente}/{servicio}/{fecha}
  tituloVideo    String // título mostrado en el cuerpo del correo (máx 100)
  cuerpoTexto    String // texto corto del correo (máx 300)
  momento        MomentoVideo
  offsetValor    Int // > 0 (validado en la app)
  offsetUnidad   UnidadOffset
  orden          Int          @default(0) // orden visual en la línea de tiempo
  activo         Boolean      @default(true) // pausar sin borrar
  createdBy      String?      @db.Uuid // Usuario que lo creó
  deletedAt      DateTime?

  servicio Servicio        @relation(fields: [servicioId], references: [id], onDelete: Restrict)
  envios   VideoEnvioLog[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([servicioId, activo])
  @@map("servicio_videos")
}

// Log idempotente de envíos: 1 fila por (cita, video). Garantía anti-duplicado vía
// índice único PARCIAL (citaId, servicioVideoId) WHERE deletedAt IS NULL, creado en la
// migración (SQL crudo). Las transiciones de ciclo de vida ACTUALIZAN esta fila
// (PENDIENTE↔CANCELADO, → ENVIADO); nunca insertan duplicados.
model VideoEnvioLog {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  citaId             String           @db.Uuid
  servicioVideoId    String           @db.Uuid
  pacienteEmail      String // snapshot del email al momento de programar
  scheduledFor       DateTime // UTC — calculado desde fecha/hora civil (America/Lima) ± offset
  estado             EstadoEnvioVideo @default(PENDIENTE)
  sentAt             DateTime? // momento real de envío
  errorDetalle       String? // último error (reintentos/ventana expirada)
  // Motivo cuando estado=CANCELADO: distingue "fuera_de_ventana" (reactivable al
  // reprogramar/editar offset) de "cita_cancelada"/"video_pausado"/"video_eliminado"
  // (no reactivables). Necesario para R2 (reactivación inversa) y R1 (revalidación).
  motivoCancelacion  String?
  intentos           Int              @default(0)
  resendEmailId      String? // id del correo en Resend (trazabilidad)
  deletedAt          DateTime?

  cita          Cita          @relation(fields: [citaId], references: [id], onDelete: Restrict)
  servicioVideo ServicioVideo @relation(fields: [servicioVideoId], references: [id], onDelete: Restrict)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([citaId])
  @@index([servicioVideoId])
  @@index([estado, scheduledFor])
  // Idempotencia "1 envío por cita+video" reforzada con índice único PARCIAL
  // (solo no borrados) creado vía SQL crudo: video_envio_log_cita_video_unico.
  @@map("video_envio_logs")
}

// Lista de exclusión de VIDEOS EDUCATIVOS: correos que NO deben recibir los videos del
// módulo. NO afecta los correos de confirmación/recordatorio (esos siguen enviándose).
// `email` se guarda en minúsculas; único parcial mientras no esté borrado. Soft-delete:
// quitar de la lista = re-habilitar futuros videos.
model VideoSupresion {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String // normalizado a minúsculas
  motivo        String?
  creadoPor     String?   @db.Uuid
  deletedAt     DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@index([email])
  // Único por email mientras esté activo: índice único PARCIAL (WHERE deletedAt IS NULL)
  // creado vía SQL crudo en la migración: video_supresiones_email_unico.
  @@map("video_supresiones")
}
