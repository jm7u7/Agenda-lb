{
  "name": "@limablue/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "worker:prod": "node dist/worker.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:generate": "prisma generate",
    "import:genexis": "ts-node --transpile-only scripts/import-genexis.ts",
    "test": "jest --runInBand",
    "proponer:aperturas": "ts-node --transpile-only scripts/proponer-aperturas.ts"
  },
  "dependencies": {
    "@limablue/shared": "*",
    "@prisma/client": "^5.14.0",
    "@types/multer": "^2.1.0",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.19.1",
    "resend": "^6.17.1",
    "socket.io": "^4.7.5",
    "svix": "^1.96.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
