# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Puerto del servidor de desarrollo de Vite.
PORT=5180

# El frontend habla con el backend a través del proxy de Vite (/api → backend),
# configurado en vite.config.ts. No se necesitan URLs absolutas aquí.
#
# Para el Sistema de Confirmación por Correo NO hace falta ninguna variable extra
# en el frontend: el flujo OAuth y los enlaces del correo se resuelven en el
# backend usando API_BASE_URL / APP_BASE_URL (ver apps/api/.env.example).
